-- Real-Time Workspace Tree Node Engine with Instance Detection & Instanced Teleport
local totalTreeLines = 0
local treeFilterText = ""

local function TraverseAndRenderNode(object, depth)
    if totalTreeLines > 150 then return end 
    if object == LocalPlayer.Character then return end

    local name = object.Name
    if treeFilterText ~= "" and not string.find(name:lower(), treeFilterText, 1, true) then
        local children = object:GetChildren()
        for i = 1, #children do TraverseAndRenderNode(children[i], depth) end
        return
    end

    totalTreeLines = totalTreeLines + 1

    local NodeButton = Instance.new("TextButton")
    NodeButton.Size = UDim2.new(1, -6, 0, 24)
    NodeButton.BackgroundTransparency = 1
    
    local indent = string.rep("    ", depth)
    local prefix = "🔹 "
    local typeColor = Theme.PartColor
    local isContainer = false

    if object:IsA("Folder") then
        isContainer = true
        local expanded = ZenithStore.ExpandedObjects[object]
        prefix = expanded and "🔽 📂 [Folder] " or "▶️ 📁 [Folder] "
        typeColor = Theme.FolderColor
    elseif object:IsA("Model") then
        isContainer = true
        local expanded = ZenithStore.ExpandedObjects[object]
        prefix = expanded and "🔽 📦 [Model] " or "▶️ 📦 [Model] "
        typeColor = Theme.ModelColor
    elseif object:IsA("MeshPart") then
        prefix = "🔮 [Mesh] "
        typeColor = Theme.MeshColor
    elseif object:IsA("BasePart") then
        prefix = "🧱 [Part] "
        typeColor = Theme.PartColor
    else
        prefix = "⚙️ [" .. object.ClassName .. "] "
        typeColor = Theme.TextDim
    end

    NodeButton.Text = indent .. prefix .. name
    NodeButton.TextColor3 = typeColor
    NodeButton.Font = Enum.Font.GothamSemibold
    NodeButton.TextSize = 10
    NodeButton.TextXAlignment = Enum.TextXAlignment.Left
    NodeButton.Parent = WorkspaceScroll

    NodeButton.MouseButton1Click:Connect(function()
        if isContainer then
            ZenithStore.ExpandedObjects[object] = not ZenithStore.ExpandedObjects[object]
            RenderRealtimeTree()
        else
            TPTargetBox.Text = name
            ZenithStore.SelectedTargetName = name
            
            NodeButton.TextColor3 = Theme.Success
            task.delay(0.4, function() NodeButton.TextColor3 = typeColor end)
            
            if object:IsA("BasePart") then
                ExecuteAdvancedPropulsion(object.CFrame)
            elseif object:IsA("Model") then
                ExecuteAdvancedPropulsion(object:GetPivot())
            end
        end
    end)

    if isContainer and (ZenithStore.ExpandedObjects[object] or treeFilterText ~= "") then
        local children = object:GetChildren()
        for i = 1, #children do
            TraverseAndRenderNode(children[i], depth + 1)
        end
    end
end

RenderRealtimeTree = function()
    for _, child in ipairs(WorkspaceScroll:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    totalTreeLines = 0
    treeFilterText = WorkspaceSearchBar.Text:lower()

    local topLevel = workspace:GetChildren()
    for i = 1, #topLevel do
        if topLevel[i].Name ~= "Terrain" then
            TraverseAndRenderNode(topLevel[i], 0)
        end
    end
    WorkspaceScroll.CanvasSize = UDim2.new(0, 0, 0, totalTreeLines * 26)
end

local searchToken = 0
RenderMapCollection = function()
    searchToken = searchToken + 1; local currentToken = searchToken
    for _, child in ipairs(ObjectsScroll:GetChildren()) do if child:IsA("Frame") then child:Destroy() end end
    local txt = SearchBar.Text:lower() 
    local count = 0
    
    for _, obj in ipairs(ZenithStore.MapCache) do
        if currentToken ~= searchToken then return end
        if obj and pcall(function() return obj.Parent end) and obj.Parent then
            local name = obj.Name
            if txt == "" or string.sub(name:lower(), 1, string.len(txt)) == txt then
                count = count + 1; if count > 45 then break end
                
                local frame = Instance.new("Frame") 
                frame.Size = UDim2.new(1, -6, 0, 34) 
                frame.BackgroundTransparency = 1
                frame.Parent = ObjectsScroll
                
                local successPrompt, promptObj = pcall(function() 
                    return obj:FindFirstChildOfClass("ProximityPrompt") or obj:FindFirstChild("ProximityPrompt", true) 
                end)
                local hasPrompt = successPrompt and promptObj
                
                local btn = Instance.new("TextButton")
                if hasPrompt then btn.Size = UDim2.new(0.72, 0, 1, 0) else btn.Size = UDim2.new(1, 0, 1, 0) end
                btn.BackgroundColor3 = Theme.Secondary
                btn.Text = "  [" .. obj.ClassName .. "] " .. name
                btn.TextColor3 = Theme.Text
                btn.Font = Enum.Font.GothamBold
                btn.TextSize = 11
                btn.TextXAlignment = Enum.TextXAlignment.Left
                btn.Parent = frame
                UI:ApplyDesign(btn, 5)
                
                btn.MouseButton1Click:Connect(function() 
                    TPTargetBox.Text = name
                    ZenithStore.SelectedTargetName = name 
                end)
                
                if hasPrompt then
                    local pBtn = Instance.new("TextButton")
                    pBtn.Size = UDim2.new(0.24, 0, 1, 0)
                    pBtn.Position = UDim2.new(0.76, 0, 0, 0)
                    pBtn.BackgroundColor3 = Theme.Purple
                    pBtn.Text = "BLINK"
                    pBtn.TextColor3 = Theme.Text
                    pBtn.Font = Enum.Font.GothamBold
                    pBtn.TextSize = 9
                    pBtn.Parent = frame
                    UI:ApplyDesign(pBtn, 5)
                    pBtn.MouseButton1Click:Connect(function() BlinkTriggerProximity(obj) end)
                end
            end
        end
    end
    ObjectsScroll.CanvasSize = UDim2.new(0, 0, 0, count * 40)
end

local function ToggleDockFrame(targetFrame)
    local state = targetFrame and targetFrame.Visible or false
    SavedFrame.Visible = false
    SettingsFrame.Visible = false
    ScriptFrame.Visible = false
    RemoteFrame.Visible = false
    CreditsFrame.Visible = false
    WorkspaceExplorerFrame.Visible = false
    if targetFrame then targetFrame.Visible = not state end
end

