-- Advanced Server Hop Optimization Methods
local function DynamicServerHop(targetMode)
    local success, servers = pcall(function()
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    
    if success and servers and servers.data then
        local targetServer = nil
        local serverList = {}
        
        for _, s in ipairs(servers.data) do
            if s.id ~= game.JobId and tonumber(s.playing) and tonumber(s.maxPlayers) then
                if s.playing < s.maxPlayers then
                    table.insert(serverList, s)
                end
            end
        end
        
        if targetMode == "HIGHER" then
            table.sort(serverList, function(a, b) return a.playing > b.playing end)
        elseif targetMode == "LOWER" then
            table.sort(serverList, function(a, b) return a.playing < b.playing end)
        end
        
        if #serverList > 0 then
            targetServer = serverList[1]
        end
        
        if targetServer then
            TeleportService:TeleportToPlaceInstance(game.PlaceId, targetServer.id, LocalPlayer)
        end
    end
end

