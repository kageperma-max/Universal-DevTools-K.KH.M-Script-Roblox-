end)

local function BlinkTriggerProximity(object)
    local prompt = object:FindFirstChildOfClass("ProximityPrompt") or object:FindFirstChild("ProximityPrompt", true)
    local char = LocalPlayer.Character
    if not prompt or not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart; local originalCFrame = hrp.CFrame; local oldHold = prompt.HoldDuration
    if ZenithStore.ForceZeroHold then prompt.HoldDuration = 0 end
    
    hrp.CFrame = (object:IsA("BasePart") and object.CFrame or object:GetPivot())
    task.wait(0.01)
    prompt:InputHoldBegin() task.wait(ZenithStore.BlinkDelay) prompt:InputHoldEnd()
    prompt.HoldDuration = oldHold; hrp.CFrame = originalCFrame
end

