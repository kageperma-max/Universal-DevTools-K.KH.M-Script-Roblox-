-- Core Indexing & Engine Teleport Controllers
local RenderMapCollection, RefreshScriptsUI, RefreshRemotesUI, RenderRealtimeTree

local function SegmentedScanning(root, callback)
    if not root then return end
    local items = root:GetDescendants()
    for i = 1, #items do
        if not ZenithStore.UIActive then break end
        callback(items[i])
        if i % 300 == 0 then task.wait() end 
    end
end

local function MasterEngineRefreshIndex()
    local tempMap, tempScr, tempRem = {}, {}, {}
    
    SegmentedScanning(workspace, function(item)
        if item:IsA("BasePart") or item:IsA("Model") then
            if item.Name ~= "Terrain" and not item:IsDescendantOf(LocalPlayer.Character) then
                table.insert(tempMap, item)
            end
        end
    end)
    
    SegmentedScanning(game:GetService("Players"), function(item)
        if item:IsA("LocalScript") or item:IsA("ModuleScript") then
            table.insert(tempScr, item)
        end
    end)

    SegmentedScanning(ReplicatedStorage, function(item)
        if item:IsA("RemoteEvent") or item:IsA("RemoteFunction") then
            table.insert(tempRem, item)
        elseif item:IsA("LocalScript") or item:IsA("ModuleScript") then
            table.insert(tempScr, item)
        end
    end)

    for _, svcName in ipairs({"StarterGui", "StarterPack", "StarterPlayer"}) do
        local ok, svc = pcall(game.GetService, game, svcName)
        if ok and svc then
            SegmentedScanning(svc, function(item)
                if item:IsA("LocalScript") or item:IsA("ModuleScript") then
                    table.insert(tempScr, item)
                end
            end)
        end
    end

    ZenithStore.MapCache = tempMap
    ZenithStore.ScriptCache = tempScr
    ZenithStore.RemoteCache = tempRem
    
    task.spawn(function()
        RenderMapCollection()
        RefreshScriptsUI()
        RefreshRemotesUI()
    end)
end

task.spawn(function()
    while ZenithStore.UIActive do
        pcall(MasterEngineRefreshIndex)
        task.wait(6)
    end
end)

-- Highly Optimized Anti-Cheat Bypass Teleportation Engine
local function ExecuteAdvancedPropulsion(targetCF)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChildOfClass("Humanoid") then return end
    local hrp = char.HumanoidRootPart
    local hum = char:FindFirstChildOfClass("Humanoid")
    
    if LocalPlayer.MaximumSimulationRadius then
        pcall(function() LocalPlayer.SimulationRadius = 1e5 end)
    end
    
    -- Anti-Falling Shield Setup
    local velocityShield = hrp.AssemblyLinearVelocity
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    
    if ZenithStore.TeleportMode == "FAST" then
        -- Fast Matrix CFrame Jumper with Velocity Zeroing to prevent tracking bans
        hum:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
        task.wait(0.02)
        hrp.CFrame = targetCF
        task.wait(0.02)
        hum:ChangeState(Enum.HumanoidStateType.Freefall)
    elseif ZenithStore.TeleportMode == "TWEEN" then
        -- Adaptive Smooth Tween Engine with structural Noclip
        local distance = (hrp.Position - targetCF.Position).Magnitude
        local calculatedDuration = distance / ZenithStore.TweenSpeed
        
        local NoclipLoop = RunService.Stepped:Connect(function()
            if char then
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
        end)
        
        hum:ChangeState(Enum.HumanoidStateType.Climbing)
        local tweenInfo = TweenInfo.new(calculatedDuration, Enum.EasingStyle.Linear)
        local twin = TweenService:Create(hrp, tweenInfo, {CFrame = targetCF})
        twin:Play()
        twin.Completed:Wait()
        
        NoclipLoop:Disconnect()
        hum:ChangeState(Enum.HumanoidStateType.Freefall)
    end
    
    task.delay(0.1, function()
        if hrp then hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end
    end)
end

local function GetTargetInstance(targetName)
    local currentTarget = targetName or ZenithStore.SelectedTargetName
    if currentTarget == "" then return nil end
    local found = workspace:FindFirstChild(currentTarget, true)
    if found then return found end
    for _, obj in ipairs(ZenithStore.MapCache) do
        if obj and obj.Name == currentTarget then return obj end
    end
    return nil
end

