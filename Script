    CopyBtn.Font = Enum.Font.GothamBold
    CopyBtn.TextSize = 10
    CopyBtn.Parent = InspectorTray
    UI:ApplyDesign(CopyBtn, 4)

    CopyBtn.MouseButton1Click:Connect(function()
        if TargetOutputText.Text ~= "No data loaded." and TargetOutputText.Text ~= "" then
