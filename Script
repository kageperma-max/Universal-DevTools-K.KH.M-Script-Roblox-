    TargetOutputText.Parent = InspectorTray
    UI:ApplyDesign(TargetOutputText, 4)

    local CopyBtn = Instance.new("TextButton")
    CopyBtn.Size = UDim2.new(0.24, 0, 1, -12)
    CopyBtn.Position = UDim2.new(0.76, 0, 0, 6)
    CopyBtn.BackgroundColor3 = accentColor
    CopyBtn.Text = "COPY"
